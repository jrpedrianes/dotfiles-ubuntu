font-family = FiraCode Nerd Font Mono
theme = Modus Vivendi

# Change divider color
split-divider-color = 282c34

# Add some nice looking padding
window-padding-x = 5
window-padding-y = 5

copy-on-select = clipboard

# Convert TERM from xterm-ghostty to xterm-256color during SSH and propagate
# COLORTERM/TERM_PROGRAM/TERM_PROGRAM_VERSION. Prevents vim/tmux/less from
# breaking on remote hosts that lack the ghostty terminfo entry.
shell-integration-features = ssh-env

# Ctrl+C - Interrupt (Cancel)
keybind = ctrl+c=text:\x03

# Ctrl+D - Delete character / EOF
keybind = ctrl+d=text:\x04

# Split navigation (override default ctrl+alt+arrows to avoid GNOME workspace conflict)
keybind = ctrl+shift+left=goto_split:left
keybind = ctrl+shift+right=goto_split:right
keybind = ctrl+shift+up=goto_split:up
keybind = ctrl+shift+down=goto_split:down

